<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.3.1/dist/css/bootstrap.min.css"
        integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.9.1/font/bootstrap-icons.css">
    <link rel="stylesheet" type="text/css" href="/stylesheets/style.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <title>BRaNT</title>
    <link rel="icon" href="https://www.arditi.pt/images/Logos/BRaNT.png">
</head>

<%- include ("partials/header") %>

    <img src="/images/cover_activities.jpg" class="img-fluid image_cover" alt="BRaNT">
    <div class="container marketing mt-5">
        <a href="/activities"><i class="bi bi-caret-left-fill" id="return_icon"></i></a>
        <br><br>
        <label class="text_color_claret">Add Activitie</label>
        <form action="/add_activitie" method="post" class="admin-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label for="exampleFormControlSelect1">Title</label>
            <input type="text" class="form-control mb-3" id="title" name="title" value="" placeholder="Enter title">
            <label for="exampleFormControlSelect1">Participations</label>
            <input type="text" class="form-control mb-3" id="participations" name="participations" value=""
                placeholder="Enter participations">
            <label for="exampleFormControlSelect1">Date</label>
            <input type="date" class="form-control w-50" id="date" name="date" value="" placeholder="Enter date">
            <label for="exampleFormControlSelect1">URL</label>
            <input type="text" class="form-control mb-3" id="url" name="url" value="" placeholder="Enter url">
            <div class="form-group">
                <label for="exampleFormControlTextarea1">Abstract</label>
                <textarea class="form-control mb-5" id="abstract" name="abstract" rows="10" value=""></textarea>
            </div>
            <button type="submit" class="btn btn-success">Submit</button>
        </form>
        <br>
    </div>
    <script>
        document.getElementById("date").value
    </script>

    <%- include ("partials/footer") %>